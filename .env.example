# Database — Neon Postgres
# Haal op via: https://neon.tech → nieuw project → connection string
DATABASE_URL=postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/brickme?sslmode=require

# Clerk Auth
# Haal op via: https://clerk.com → nieuw project → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# Anthropic Claude API
# Haal op via: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-xxx

# Stripe (later toevoegen)
# Haal op via: https://dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Admin — Jouw Clerk User ID (te vinden in Clerk Dashboard → Users)
# Dit account krijgt automatisch superadmin-rechten
ADMIN_USER_ID=user_xxx
